generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum CloudProvider {
  AWS
  AZURE
  GCP
}

enum PlanStatus {
  DRAFT
  APPROVED
  EXECUTED
  FAILED
}

enum LogStatus {
  PENDING
  SUCCESS
  ERROR
}

model Organization {
  id                    String                 @id @default(uuid())
  name                  String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  usageMetrics          UsageMetric[]
  reservationPortfolios ReservationPortfolio[]
  executionPlans        ExecutionPlan[]
  transactionLogs       TransactionLog[]
}

model UsageMetric {
  id             String        @id @default(uuid())
  org            Organization  @relation(fields: [orgId], references: [id])
  orgId          String
  provider       CloudProvider
  computeUnit    Float         // Normalized unit of compute
  cost           Float
  usage          Float         // Raw usage value
  timestamp      DateTime
  createdAt      DateTime      @default(now())

  @@index([orgId, timestamp])
}

model ReservationPortfolio {
  id                         String        @id @default(uuid())
  org                        Organization  @relation(fields: [orgId], references: [id])
  orgId                      String
  provider                   CloudProvider
  instanceType               String
  region                     String
  count                      Int
  normalizedUnitsPerInstance Float
  expiryDate                 DateTime
  createdAt                  DateTime      @default(now())

  @@index([orgId, provider])
}

model ExecutionPlan {
  id              String        @id @default(uuid())
  org             Organization  @relation(fields: [orgId], references: [id])
  orgId           String
  planType        String        // e.g., "SAVINGS_RESERVED_INSTANCES"
  recommendations Json          // Detailed recommendations
  roiScore        Float
  status          PlanStatus    @default(DRAFT)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([orgId, status])
}

model TransactionLog {
  id               String        @id @default(uuid())
  org              Organization  @relation(fields: [orgId], references: [id])
  orgId            String
  idempotencyKey   String        @unique
  status           LogStatus     @default(PENDING)
  payload          Json
  hash             String        // Crypto hash for integrity
  error            String?
  createdAt        DateTime      @default(now())

  @@index([orgId, idempotencyKey])
}
