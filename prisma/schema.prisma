generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum CloudProvider {
  AWS
  AZURE
  GCP
}

enum CommitmentTerm {
  ONE_YEAR
  THREE_YEAR
}

enum OfferingClass {
  STANDARD
  CONVERTIBLE
}

enum PlanStatus {
  DRAFT
  APPROVED
  PROCESSING
  COMPLETED
  FAILED
}

enum SyncStatus {
  PENDING
  SYNCING
  SUCCESS
  ERROR
}

model Organization {
  id               String          @id @default(uuid())
  name             String
  billingAccountId String          @unique
  riskTolerance    Float           @default(0.2)
  createdAt        DateTime        @default(now())
  cloudAccounts    CloudAccount[]
  executionPlans   ExecutionPlan[]
}

model CloudAccount {
  id                    String                 @id @default(uuid())
  orgId                 String
  provider              CloudProvider
  accountAlias          String
  credentials           Json
  lastSync              DateTime               @default(now())
  organization          Organization           @relation(fields: [orgId], references: [id])
  usageMetrics          UsageMetric[]
  reservationPortfolios ReservationPortfolio[]

  @@index([orgId, provider])
}

model UsageMetric {
  id              String       @id @default(uuid())
  accountId       String
  timestamp       DateTime
  instanceFamily  String
  region          String
  normalizedUnits Int
  onDemandCost    Float
  cloudAccount    CloudAccount @relation(fields: [accountId], references: [id])

  @@index([accountId, timestamp, instanceFamily])
}

model ReservationPortfolio {
  id             String         @id @default(uuid())
  accountId      String
  reservationId  String         @unique
  termYears      CommitmentTerm
  offeringClass  OfferingClass
  hourlyRate     Float
  totalUpfront   Float
  state          String         @default("ACTIVE")
  expirationDate DateTime
  cloudAccount   CloudAccount   @relation(fields: [accountId], references: [id])

  @@index([accountId, state])
}

model Recommendation {
  id                      String         @id @default(uuid())
  executionPlanId         String
  instanceFamily          String
  region                  String
  recommendedQuantity     Int
  term                    CommitmentTerm
  roiScore                Float
  estimatedMonthlySavings Float
  status                  PlanStatus     @default(DRAFT)
  executionPlan           ExecutionPlan  @relation(fields: [executionPlanId], references: [id])
}

model ExecutionPlan {
  id                    String           @id @default(uuid())
  organizationId        String
  generatedAt           DateTime         @default(now())
  totalEstimatedSavings Float
  status                PlanStatus
  approvedById          String?
  organization          Organization     @relation(fields: [organizationId], references: [id])
  recommendations       Recommendation[]
  transactionLogs       TransactionLog[]
}

model TransactionLog {
  id              String        @id @default(uuid())
  idempotencyKey  String        @unique
  executionPlanId String
  vendorResponse  Json
  status          SyncStatus
  retryCount      Int           @default(0)
  executionPlan   ExecutionPlan @relation(fields: [executionPlanId], references: [id])
}
